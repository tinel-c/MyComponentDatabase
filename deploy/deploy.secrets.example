# Copy values into GitHub: Settings → Secrets and variables → Actions → New repository secret.
# Do NOT commit real secrets. Optional local file: deploy/.env.deploy (gitignored).
#
# Required repository secrets (names must match exactly):
#   DEPLOY_HOST          — VPS hostname or IP (e.g. part-db.bogza.ro)
#   DEPLOY_USER          — SSH user (e.g. deploy)
#   DEPLOY_SSH_PASSWORD  — That user's SSH login password (plain text)
#
# Optional:
#   DEPLOY_SSH_PORT      — SSH port if not 22 (omit to use 22)
#
# Server: sshd must allow password auth for that user (e.g. PasswordAuthentication yes
# in /etc/ssh/sshd_config, or a Match User deploy block). Reload sshd after changes.

# --- SSH / deploy (example values) ---
DEPLOY_HOST=part-db.bogza.ro
DEPLOY_USER=deploy
DEPLOY_SSH_PORT=22
DEPLOY_SSH_PASSWORD=

# Private GitHub repo: on the server, configure a deploy key or credential helper so
#   git pull in /opt/warehouse/blue and /opt/warehouse/green works for the deploy user.

# --- App (production) — same as web/.env ---
AUTH_SECRET=
AUTH_URL=https://part-db.bogza.ro
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
ADMIN_EMAIL=

# Optional
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_ID=
# NEXT_PUBLIC_TME_LOCALE=ro
