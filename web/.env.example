# Database (SQLite by default)
DATABASE_URL="file:./dev.db"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-long-random-string"
# Public URL of the app (e.g. http://localhost:3000). Required for OAuth in production.
AUTH_URL="http://localhost:3000"

# Google OAuth — create an OAuth 2.0 "Web application" client at:
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URI (must match exactly): {AUTH_URL}/api/auth/callback/google
# Example: http://localhost:3000/api/auth/callback/google
#
# Use either pair (do not leave empty — or Google returns "Missing required parameter: client_id"):
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Alternative names (same values — supported for compatibility with common tutorials):
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Seed: first admin user email (must match Google account you sign in with; override if needed)
ADMIN_EMAIL="tinel.c@gmail.com"
