# Database (SQLite by default)
DATABASE_URL="file:./dev.db"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-long-random-string"
# Public URL of the app (e.g. http://localhost:3000). Required for OAuth in production.
AUTH_URL="http://localhost:3000"

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Seed: first admin user email (must match Google account you sign in with)
ADMIN_EMAIL="admin@example.com"
