generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

model User {
  id             String               @id @default(cuid())
  name           String?
  email          String?              @unique
  emailVerified  DateTime?
  image          String?
  role           Role                 @default(USER)
  accounts       Account[]
  sessions       Session[]
  categoryAccess UserCategoryAccess[]
  auditLogs      AuditLog[]
}

/** Append-only change history for admin audit; optional revert for UPDATE rows. */
model AuditLog {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  model      String
  recordId   String
  recordName String?
  before     Json?
  after      Json?
  reverted   Boolean  @default(false)

  @@index([createdAt])
  @@index([model])
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserCategoryAccess {
  userId     String
  categoryId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([userId, categoryId])
}

model Category {
  id         String               @id @default(cuid())
  name       String
  parentId   String?
  parent     Category?            @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children   Category[]           @relation("CategoryTree")
  parts      Part[]
  userAccess UserCategoryAccess[]
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@index([parentId])
}

model StorageLocation {
  id        String            @id @default(cuid())
  name      String
  parentId  String?
  parent    StorageLocation?  @relation("LocationTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  StorageLocation[] @relation("LocationTree")
  partsDefault Part[]         @relation("PartDefaultLocation")
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([parentId])
}

model Part {
  id                String           @id @default(cuid())
  /** Public short id for URLs /p/{partNumber} — sequential from 1 */
  partNumber        Int              @unique
  internalSku       String?          @unique
  name              String
  mpn               String?
  manufacturer      String?
  description       String?
  /** Optional image URL for cards / detail page */
  imageUrl          String?
  quantityOnHand    Int              @default(0)
  reorderMin        Int?
  unit              String           @default("pcs")
  categoryId        String?
  category          Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  defaultLocationId String?
  defaultLocation   StorageLocation? @relation("PartDefaultLocation", fields: [defaultLocationId], references: [id], onDelete: SetNull)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  purchaseLinks     PartPurchaseLink[]
  images            PartImage[]

  @@index([categoryId])
  @@index([defaultLocationId])
  @@index([name])
  @@index([partNumber])
}

/** User-curated “where to buy” links (distributors, shops). */
model PartPurchaseLink {
  id        String   @id @default(cuid())
  partId    String
  part      Part     @relation(fields: [partId], references: [id], onDelete: Cascade)
  label     String
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([partId])
}

/** Photos copied from local `Components/` folders or added later; URLs point under `/public/part-assets/`. */
model PartImage {
  id        String   @id @default(cuid())
  partId    String
  part      Part     @relation(fields: [partId], references: [id], onDelete: Cascade)
  /** App URL e.g. `/part-assets/comp-00036/00-photo.jpg` */
  url       String
  sortOrder Int      @default(0)
  caption   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([partId])
}
